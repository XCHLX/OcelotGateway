{
  "Routes": [
    {
      "UpstreamPathTemplate": "/api/{url}", //上游Api请求路由规则
      "DownstreamPathTemplate": "/api/{url}", //网关转发到下游路由规则
      "DownstreamScheme": "http", // 转发协议
      "UpstreamHttpMethod": [
        "GET",
        "POST"
      ],
      // 使用服务发现
      "ServiceName": "DmyOpenApiService",

      "RouteIsCaseSensitive": false, // 路径是否区分大小写，false表示不区分
      "LoadBalancerOptions": { // 负载均衡选项
        "Type": "LeastConnection" // 负载均衡策略类型，使用最少连接数策略
        //"Type": "RoundRobin" // 负载均衡策略类型，使用轮询策略"
      },
      "UpstreamHeaderTransform": { // 上游请求头转换配置
        "X-Forwarded-For": "{RemoteIpAddress}" // 将上游请求头的X-Forwarded-For设置为远程IP地址
      },
      "RateLimitOptions": { // 限流选项配置
        "EnableRateLimiting": true, // 是否启用限流
        "ClientIdHeader": "X-Guest-Id", // 用于标识客户端的请求头
        "DisableRateLimitHeaders": false, // 是否禁用限流相关的响应头
        "Period": "1s", // 限流时间周期
        "Limit": 10, // 时间周期内允许的最大请求数
        "PeriodTimespan": 5, // 封禁时长：达到上限后，多少秒内不能访问
        "HttpStatusCode": 429, // 超出限流时返回的HTTP状态码
        "QuotaExceededMessage": "Too many requests. Please try again later." // 超出限流时返回的消息
      },
      "QoSOptions": { // 服务质量(QoS)选项配置
        "ExceptionsAllowedBeforeBreaking": 3, // 在断路器打开前允许的异常次数
        "DurationOfBreak": 10000, // 断路器打开后的持续时间（毫秒）
        "TimeoutValue": 3000 // 请求超时时间（毫秒）
      }
    }

  ],
  "GlobalConfiguration": { // 全局配置
    "BaseUrl": "http://127.0.0.1:7000", // 网关的基础URL
    "ServiceDiscoveryProvider": {
      "Type": "MyCustom"
    }
  }
}