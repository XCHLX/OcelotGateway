{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "System.Net.Http.HttpClient.Default.ClientHandler": "Warning",
      "System.Net.Http.HttpClient.Default": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ServiceHealthCheckIntervalSeconds": 10, // 服务健康检查的时间间隔，单位为秒
  "AlertThreshold": 1, // 健康检查失败次数超过该值时触发警报,
  "AlertTimeWindow": 300, // 警报时间窗口，单位为秒,
  // 自定义服务发现和健康检查配置
  "ServiceDiscovery": [
    {
      "ServiceName": "DmyOpenApiService",
      "Alias": "多卖云openApi",

      "DownstreamHostAndPorts": [ // 下游服务的主机和端口列表，用于负载均衡
        {
          "Host": "127.0.0.1", //下游地址
          "Port": 8099 //下游端口号
        },
        {
          "Host": "127.0.0.1",
          "Port": 8098
        }
      ],
      "Health": "/api/DemoOpen/Monitor", // 健康检查路径
      "TimeOut": 3,
      "DingDingWebHook": "", // 钉钉机器人Webhook地址
      "DingDingSecret": "" // 钉钉机器人安全设置
    }
  ]
}